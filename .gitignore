src/scan/state/blocklist.json
src/scan/state/seen-chats.json
src/scan/state/last-scan.json
src/scan/state/chatlist-snapshot.txt
src/scan/state/out/*
!src/scan/state/out/.gitkeep

# DIKW push config (contains bearer token) and offline retry queue
src/scan/state/dikw.json
src/scan/state/outbox.json

# os / editor
.DS_Store
